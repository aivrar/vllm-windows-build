+/// Process group helper functions for managing the Python subprocess and its
+/// potential children in a platform-aware way.
+#[cfg(windows)]
+mod process_group {
+    use super::*;
+
+    const CREATE_NEW_PROCESS_GROUP: u32 = 0x0000_0200;
+
+    /// Place the Python child into its own process group. Windows does not have
+    /// POSIX signals, so shutdown uses taskkill to terminate the process tree.
+    pub fn configure(command: &mut Command) {
+        command.creation_flags(CREATE_NEW_PROCESS_GROUP);
+    }
+
+    /// Ask taskkill to terminate the managed Python process tree. This can fail
+    /// for console subprocesses that require forceful termination, so shutdown
+    /// continues to the force-kill path if the process is still alive.
+    pub fn terminate(pid: u32) -> Result<()> {
+        let _ = taskkill(pid, false);
+        Ok(())
+    }
+
+    /// Force-kill the managed Python process tree.
+    pub fn kill(pid: u32) -> Result<()> {
+        taskkill(pid, true)
+    }
+
+    fn taskkill(pid: u32, force: bool) -> Result<()> {
+        let pid_arg = pid.to_string();
+        let mut command = StdCommand::new("taskkill");
+        command.args(["/PID", &pid_arg, "/T"]);
+        if force {
+            command.arg("/F");
+        }
+
+        let status = command
+            .status()
+            .context("failed to invoke taskkill for managed engine process tree")?;
+        if status.success() {
+            return Ok(());
+        }
+
+        anyhow::bail!("taskkill failed for managed engine process tree with status {status}");
+    }
+}
