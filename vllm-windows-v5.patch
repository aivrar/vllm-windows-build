+    # CPU staging buffer that PyTorch's CPU->GPU copy_() allocates).
+    # Below the threshold we keep the CPU mmap view (zero copy).
+    LARGE_TENSOR_BYTES = 256 * 1024 * 1024  # 256 MiB
+
