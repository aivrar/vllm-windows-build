+                for off in range(0, nbytes, chunk_bytes):
+                    n = min(chunk_bytes, nbytes - off)
+                    cpu_chunk = cpu_u8[off:off + n].contiguous()
+                    gpu_u8[off:off + n].copy_(cpu_chunk, non_blocking=False)
+                    del cpu_chunk
