+    safetensors' default mmap path and even plain ``torch.empty(nbytes)``
+    allocations fail when fragmentation eats commit budget.
+
+    Strategy:
+        1. ``numpy.memmap`` the safetensors file. This uses the file
+           itself as backing storage — no process commit charge.
+        2. For each tensor: build a zero-copy ``torch.from_numpy`` view
+           over the mmap'd bytes (uint8). Reinterpret as the target
+           dtype/shape.
+        3. Copy that view directly to GPU memory before yielding. The
+           downstream weight loader sees a GPU tensor, so its
+           ``.copy_(loaded_weight)`` becomes a GPU→GPU copy and never
+           needs a large CPU staging buffer.
+
+    The temporary GPU buffer is released after the model loader copies
+    it into the persistent param tensor (the next iteration overwrites
+    the reference, Python GC + torch's caching allocator reclaim it).
+    """
+    import struct
+    import numpy as np
+
+    # Map safetensors dtype string -> (torch dtype, numpy dtype if any, item bytes)
+    dtype_table: dict[str, tuple[torch.dtype, np.dtype | None, int]] = {
+        "F64":     (torch.float64, np.dtype(np.float64), 8),
+        "F32":     (torch.float32, np.dtype(np.float32), 4),
+        "F16":     (torch.float16, np.dtype(np.float16), 2),
+        "BF16":    (torch.bfloat16, None,                2),
+        "F8_E4M3": (torch.float8_e4m3fn, None,           1),
+        "F8_E5M2": (torch.float8_e5m2,   None,           1),
+        "I64":     (torch.int64, np.dtype(np.int64), 8),
+        "I32":     (torch.int32, np.dtype(np.int32), 4),
+        "I16":     (torch.int16, np.dtype(np.int16), 2),
+        "I8":      (torch.int8,  np.dtype(np.int8),  1),
+        "U8":      (torch.uint8, np.dtype(np.uint8), 1),
+        "BOOL":    (torch.bool,  np.dtype(np.bool_), 1),
+    }
