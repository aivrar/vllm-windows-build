+        shape=(data_bytes,),
+    )
+
+    items = [
+        (k, v) for k, v in header.items()
+        if k != "__metadata__" and isinstance(v, dict)
+    ]
+    items.sort(key=lambda kv: kv[1]["data_offsets"][0])
+
